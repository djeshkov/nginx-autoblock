# nginx-autoblock configuration
# Copy to /etc/nginx-autoblock/config.env and edit for your environment.
# All lines are KEY=VALUE; '#' starts a comment; quotes optional.

# ─── Paths ────────────────────────────────────────────────────

# Nginx access log to scan
access_log=/var/log/nginx/access.log

# Output file — list of CIDRs to block. Include in nginx via geo (see nginx/blacklist.conf)
blocked_conf=/etc/nginx/blocked-subnets.conf

# Whitelist of CIDRs that are NEVER auto-blocked (search engines, AI bots, your own IPs)
whitelist=/etc/nginx/autoblock-whitelist.conf

# Offline ASN database (download from iptoasn.com — see scripts/refresh-asn-db.sh)
asn_db=/var/lib/nginx-autoblock/ip2asn-combined.tsv.gz

# Persistent cache of ip-api.com results
rep_cache=/var/cache/nginx-autoblock/reputation.json

# Log of decisions (BLOCK, EXTEND, UNBLOCK)
log_file=/var/log/nginx-autoblock.log


# ─── Detection ────────────────────────────────────────────────

# Sliding window for analysis (minutes)
window_minutes=30

# Minimum requests in window before a subnet is even evaluated.
# Subnets below this are ignored to avoid scoring noise.
min_requests=200

# Score required to trigger an auto-block (max possible score is 11)
score_threshold=7

# How long an auto-block lasts. Refreshed on every re-trigger.
ttl_days=7

# How long ip-api results are cached (per subnet)
rep_cache_ttl_days=7

# Subnet prefix for IPv6 grouping. /64 typically = one customer (mobile carrier or ISP).
# Smaller numbers = wider grouping (more aggressive). /48 = bigger blocks (riskier).
ipv6_prefix=64


# ─── Target paths ─────────────────────────────────────────────
# Comma-separated path prefixes. A request counts toward the "target" signal if
# it starts with one of these — these are the endpoints bots typically hammer
# (API, search, etc.). Tune to your application.
target_paths=/api/,/search

# Comma-separated path prefixes that are CHECKED FIRST and EXCLUDE the request
# from the target ratio. Use for legitimate admin/internal traffic which would
# otherwise look like API hammering.
excluded_paths=/api/admin/


# ─── ip-api.com (reputation enrichment) ───────────────────────

# Free tier: 45 batch requests/min, no key required.
# Set to false to skip reputation enrichment and fall back to offline ASN
# keyword matching only.
use_ipapi=true

# Don't change unless you know what you're doing. HTTPS requires Pro plan.
ipapi_batch_url=http://ip-api.com/batch?fields=query,proxy,hosting,mobile,isp,as,country

# HTTP timeout for ip-api calls (seconds)
ipapi_timeout=10

# Max IPs per batch request (ip-api supports up to 100)
ipapi_batch_size=100
