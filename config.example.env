# nginx-autoblock configuration
# Copy to /etc/nginx-autoblock/config.env and edit for your environment.
# All lines are KEY=VALUE; '#' starts a comment; quotes optional.

# ─── Paths ────────────────────────────────────────────────────

# Nginx access log to scan
access_log=/var/log/nginx/access.log

# Output file — list of CIDRs to block. Include in nginx via geo (see nginx/blacklist.conf)
blocked_conf=/etc/nginx/blocked-subnets.conf

# Whitelist of CIDRs that are NEVER auto-blocked (search engines, AI bots, your own IPs)
whitelist=/etc/nginx/autoblock-whitelist.conf

# Offline ASN database (download from iptoasn.com — see scripts/refresh-asn-db.sh)
asn_db=/var/lib/nginx-autoblock/ip2asn-combined.tsv.gz

# Persistent cache of ip-api.com results
rep_cache=/var/cache/nginx-autoblock/reputation.json

# Log of decisions (BLOCK, EXTEND, UNBLOCK)
log_file=/var/log/nginx-autoblock.log


# ─── Detection ────────────────────────────────────────────────

# Sliding window for analysis (minutes)
window_minutes=30

# Minimum requests in window before a subnet is even evaluated.
# Subnets below this are ignored to avoid scoring noise.
min_requests=200

# Score required to trigger an auto-block (max possible score is 11)
score_threshold=7

# How long an auto-block lasts. Refreshed on every re-trigger.
ttl_days=7

# How long ip-api results are cached (per subnet)
rep_cache_ttl_days=7

# Subnet prefix for IPv6 grouping. /64 typically = one customer (mobile carrier or ISP).
# Smaller numbers = wider grouping (more aggressive). /48 = bigger blocks (riskier).
ipv6_prefix=64


# ─── Target paths ─────────────────────────────────────────────
# Comma-separated path prefixes. A request counts toward the "target" signal if
# it starts with one of these — these are the endpoints bots typically hammer
# (API, search, etc.). Tune to your application.
target_paths=/api/,/search

# Comma-separated path prefixes that are CHECKED FIRST and EXCLUDE the request
# from the target ratio. Use for legitimate admin/internal traffic which would
# otherwise look like API hammering.
excluded_paths=/api/admin/


# ─── ip-api.com (reputation enrichment) ───────────────────────

# Free tier: 45 batch requests/min, no key required.
# Set to false to skip reputation enrichment and fall back to offline ASN
# keyword matching only.
use_ipapi=true

# Don't change unless you know what you're doing. HTTPS requires Pro plan.
ipapi_batch_url=http://ip-api.com/batch?fields=query,proxy,hosting,mobile,isp,as,country

# HTTP timeout for ip-api calls (seconds)
ipapi_timeout=10

# Max IPs per batch request (ip-api supports up to 100)
ipapi_batch_size=100


# ─── Per-IP behavioral scoring (path-agnostic, added v1.1) ────
# Optional second pass that scores individual IPs by behavioral fingerprint
# (no-assets, no-referer, cloud-ASN, old-Chrome, headless-UA, etc.) regardless
# of how many requests they made.
#
# Disabled by default for backward compatibility. Enable to catch distributed
# scrapers (1 req per IP from many different cloud IPs) that the /24 subnet
# pass cannot detect by design.

per_ip_enabled=false

# Output file for per-IP /32 bans. Separate from blocked_conf so the subnet
# pass output is not touched. Include in nginx via geo (see nginx/blacklist.conf).
blocked_ips_conf=/etc/nginx/blocked-ips.conf

# Score threshold (max ~14). Backtest on real Laravel-site traffic (116k log
# lines, 25k IPs): threshold=9 yields ~1.5% of IPs banned, 0% false-positive
# rate after UA whitelist. Lower thresholds (7-8) catch more but require more
# careful whitelist tuning.
per_ip_threshold=9

# Per-IP auto-ban TTL (independent from subnet TTL).
per_ip_ttl_days=7

# Hostnames considered "internal" — referers from these are counted as
# internal navigation (good signal), others as external (slight bot signal).
# Comma-separated. If empty, every referer is treated as external.
internal_ref_hosts=

# Server's own IPs — skipped from scoring (health-checks, self-curls,
# autoblock probes). Comma-separated.
self_ips=

# Chrome major-version below which the UA is considered scraper-like (real
# users auto-update; scrapers pin old versions). Tune ~6 months behind
# current stable. Set 0 to disable this signal.
per_ip_chrome_min_version=142


# ─── UA-cluster pass (path-agnostic, added v1.2) ──────────────
# Optional third pass that groups requests by User-Agent and flags a UA shared
# across an abnormal number of distinct IPs when the cluster sits on
# hosting/datacenter infrastructure and behaves like a bot.
#
# Disabled by default. Enable to catch distributed scraping botnets that the
# subnet AND per-IP passes both miss by design — hundreds of IPs, ~1 request
# each, all rotating a tiny pool of User-Agent strings. The shared UA is an
# aggregate property no per-IP scorer can see.
#
# A genuinely popular real-browser UA is also shared by many IPs, but those
# IPs are residential and behave normally, so the cluster scores low. ASN type
# and behavior are the discriminators — not raw IP count.

ua_cluster_enabled=false

# Output file for UA-cluster /32 bans. Separate from the other passes' files.
# Include in nginx via geo (see nginx/blacklist.conf).
blocked_ua_cluster_conf=/etc/nginx/blocked-ua-clusters.conf

# Minimum distinct IPs sharing one UA before the cluster is evaluated. Below
# this, a UA is too small to be a meaningful cluster. Raise on high-traffic
# sites, lower if you expect smaller botnets.
ua_cluster_min_ips=30

# Cluster score threshold (max 13). See docs/SCORING.md for the signal table.
ua_cluster_threshold=7

# UA-cluster auto-ban TTL (independent from the other passes).
ua_cluster_ttl_days=7
