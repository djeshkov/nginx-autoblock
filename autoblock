    "leaseweb", "netcup", "contabo", "choopa", "stark industries",
    # Chinese hosting / CDN
    "baidu", "alibaba", "tencent", "huawei cloud", "sinnet", "ucloud", "kingsoft",
    # Russian / CIS hosting
    "selectel", "beget", "firstbyte", "mts cloud",
    # Other
    "m247", "hurricane electric", "datapacket", "wp engine", "rackspace",
