# Whitelist / ASN keyword fallback

def load_whitelist(path):
    nets = []
    if not Path(path).exists():
        return nets
    for line in Path(path).read_text().splitlines():
        s = line.split("#", 1)[0].strip()
        if not s:
            continue
        try:
            nets.append(ipaddress.ip_network(s, strict=False))
        except ValueError:
            logging.warning("bad whitelist CIDR: %s", s)
    return nets


def is_whitelisted(net, whitelist):
    for w in whitelist:
        if net.overlaps(w):
            return True
    return False


def load_asn_db(path):
    """Load iptoasn-combined.tsv.gz. Returns sorted ranges for bisect lookup."""
    p = Path(path)
    if not p.exists():
        return None
    starts4, ends4, descs4 = [], [], []
    starts6, ends6, descs6 = [], [], []
    with gzip.open(p, "rt", encoding="utf-8", errors="ignore") as f:
        for line in f:
            parts = line.rstrip("\n").split("\t")
            if len(parts) != 5:
                continue
            start_ip, end_ip, _asn, _cc, desc = parts
            try:
                s_int = int(ipaddress.ip_address(start_ip))
                e_int = int(ipaddress.ip_address(end_ip))
            except ValueError:
                continue
            if ":" in start_ip:
                starts6.append(s_int); ends6.append(e_int); descs6.append(desc)
            else:
                starts4.append(s_int); ends4.append(e_int); descs4.append(desc)
    return (starts4, ends4, descs4, starts6, ends6, descs6)


def asn_lookup(net, db):
    if db is None:
        return None
    starts4, ends4, descs4, starts6, ends6, descs6 = db
    ip_int = int(net.network_address)
    if isinstance(net, ipaddress.IPv4Network):
        starts, ends, descs = starts4, ends4, descs4
    else:
        starts, ends, descs = starts6, ends6, descs6
    idx = bisect.bisect_right(starts, ip_int) - 1
    if 0 <= idx < len(starts) and starts[idx] <= ip_int <= ends[idx]:
        return descs[idx]
    return None


def is_hosting_asn(desc):
    if not desc:
        return False
    d = desc.lower()
    return any(kw in d for kw in HOSTING_KEYWORDS)


# ─────────────────────────────────────────────────────────────────
# Per-IP behavioral scoring — path-agnostic, works with N=1 request
# (Added in v1.1.)
#
# This is an additive pass that runs ALONGSIDE the existing /24 subnet
# aggregation. Subnet pass catches concentrated botnets; per-IP pass
# catches distributed scrapers where each IP makes 1-2 requests and no /24
# accumulates enough traffic to trip.
#
# Disabled by default (per_ip_enabled=false). When enabled, output goes to
# a SEPARATE file (blocked_ips_conf) at /32 granularity, leaving the
# subnet-pass output untouched.

# UA max length stored per-IP. Googlebot Mobile UA is ~198 chars; truncating
# below that loses the "Googlebot/2.1" suffix and breaks claimed-bot detection.
UA_MAX_LENGTH = 250

# Today (2026-05) current Chrome is ~148. Anything older than 6 months is a
# scraper fingerprint — real users auto-update.
# Tune via config: per_ip_chrome_min_version.
SUSPICIOUS_CHROME_THRESHOLD = 142

# UAs that are trusted infrastructure / Google Privacy Sandbox / CDN fetchers.
# These IPs are skipped regardless of behavioral score.
UA_WHITELIST_RE = re.compile(
    r"(Privacy Preserving Prefetch Proxy|imgix/|Pingdom|UptimeRobot|StatusCake|Site24x7)",
    re.I,
)

# UAs that CLAIM to be a known crawler. Subject to PTR + forward-DNS
# verification before whitelisting. Unverified claims may indicate fake-bot
# spoofing in which case the IP is re-classified as blockable.
CLAIMED_BOT_RE = re.compile(
    r"(Googlebot|bingbot|BingPreview|YandexBot|YandexImages|YandexMobileBot|"
    r"AhrefsBot|DuckDuckBot|Amzn-SearchBot|Amazonbot|Applebot|"
    r"FacebookExternalHit|FacebookBot|meta-externalagent|meta-webindexer|"
    r"Sogou web spider|YisouSpider|Bytespider|PetalBot|baiduspider|"
    r"SemrushBot|MJ12bot|DataForSeoBot|MojeekBot|BLEXBot|"
    r"GoogleOther|Google-CloudVertexBot|Google-InspectionTool|"
    r"CCBot|ClaudeBot|GPTBot|ChatGPT-User|PerplexityBot|OAI-SearchBot|"
    r"Twitterbot|TelegramBot|WhatsApp|Slackbot|LinkedInBot|Discordbot)",
    re.I,
)

# UA → PTR domain-suffix map for verified-bot DNS verification.
# Source: vendor docs (e.g., https://developers.google.com/search/docs/crawling-indexing/verifying-googlebot).
VERIFIED_BOT_PTR_SUFFIXES = {
    "Googlebot":      (".googlebot.com", ".google.com"),
    "bingbot":        (".search.msn.com",),
    "BingPreview":    (".search.msn.com",),
    "YandexBot":      (".yandex.com", ".yandex.ru", ".yandex.net"),
    "AhrefsBot":      (".ahrefs.com", ".ahrefs.net"),
    "DuckDuckBot":    (".duckduckgo.com",),
    "Amzn-SearchBot": (".amazon.com", ".aws.com"),
    "Amazonbot":      (".amazon.com", ".aws.com"),
    "Applebot":       (".applebot.apple.com", ".apple.com"),
    "FacebookBot":    (".facebook.com", ".fbsv.net"),
    "meta-externalagent": (".facebook.com", ".fbsv.net"),
    "PetalBot":       (".aspiegel.com", ".petalsearch.com"),
}

HEADLESS_UA_RE = re.compile(
    r"(HeadlessChrome|PhantomJS|Puppeteer|Playwright|Selenium|Scrapy|"
    r"python-requests|node-fetch|Go-http-client|libwww-perl)",
    re.I,
)

CHROME_VERSION_RE = re.compile(r"Chrome/(\d+)\.")

# Asset extensions that real browsers fetch alongside HTML.
ASSET_RE = re.compile(
    r"\.(?:js|css|png|jpg|jpeg|webp|gif|svg|ico|woff2?|ttf|eot|webmanifest|map)(?:\?|$)",
    re.I,
)


def extract_chrome_version(ua):
    """Return major Chrome version as int, or None if not a Chrome UA."""
    m = CHROME_VERSION_RE.search(ua or "")
    return int(m.group(1)) if m else None


def is_old_chrome(ua, threshold=SUSPICIOUS_CHROME_THRESHOLD):
    v = extract_chrome_version(ua)
    return v is not None and v < threshold


def is_ua_whitelisted(ua_set):
    """True if any UA in the set matches the safe-UA whitelist regex."""
    return any(UA_WHITELIST_RE.search(ua) for ua in ua_set if ua)


def is_claimed_bot(ua_set):
    """True if any UA claims to be a known crawler (subject to PTR verify)."""
    return any(CLAIMED_BOT_RE.search(ua) for ua in ua_set if ua)


def claimed_bot_family(ua_set):
    """Return the matched bot-family name for PTR verification, or None."""
    for ua in ua_set:
        if not ua:
            continue
        for fam in VERIFIED_BOT_PTR_SUFFIXES:
            if fam.lower() in ua.lower():
                return fam
    return None


def scan_log_per_ip(cfg, window_start=None):
    """Parse nginx access log into per-IP behavioral stats.

    Returns dict[ip_str] -> stats dict with:
        reqs, assets, no_ref, ext_ref, int_ref, status_4xx, paths(set), ua_set(set),
        first_ts, last_ts.

    `internal_ref_hosts` in cfg determines what counts as internal-vs-external
    referer (list of hostnames; falls back to empty list = all referers are external).
    """
    internal_hosts = cfg.get("internal_ref_hosts", [])
    if isinstance(internal_hosts, str):
        internal_hosts = [h.strip() for h in internal_hosts.split(",") if h.strip()]

    stats = defaultdict(lambda: {
        "reqs": 0, "assets": 0,
        "no_ref": 0, "ext_ref": 0, "int_ref": 0,
        "status_4xx": 0,
        "paths": set(), "ua_set": set(),
        "first_ts": None, "last_ts": None,
    })

    p = Path(cfg["access_log"])
    if not p.exists():
        logging.error("access log not found: %s", p)
        return stats

    with p.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            m = LOG_RE.match(line)
            if not m:
                continue
            ip, ts_str, _method, path, _proto, status, referer, ua = m.groups()
            try:
                ts = datetime.strptime(ts_str, "%d/%b/%Y:%H:%M:%S %z")
            except ValueError:
                continue
            if window_start is not None and ts < window_start:
                continue
            s = stats[ip]
            s["reqs"] += 1
            s["paths"].add(path.split("?", 1)[0][:120])
            if ASSET_RE.search(path):
                s["assets"] += 1
            if referer == "-" or not referer:
                s["no_ref"] += 1
            elif any(h in referer for h in internal_hosts):
                s["int_ref"] += 1
            else:
                s["ext_ref"] += 1
            if status.startswith("4"):
                s["status_4xx"] += 1
            s["ua_set"].add((ua or "")[:UA_MAX_LENGTH])
            ts_epoch = ts.timestamp()
            if s["first_ts"] is None or ts_epoch < s["first_ts"]:
                s["first_ts"] = ts_epoch
            if s["last_ts"] is None or ts_epoch > s["last_ts"]:
                s["last_ts"] = ts_epoch
    return stats


def find_blockable_ips(cfg, asn_lookup_fn, window_start=None):
    """Run the per-IP behavioral pass: returns list of {ip, score, reasons, added, expires}.

    `asn_lookup_fn`: callable (ip_str) -> asn_description_str. Pass a closure
    that captures the asn_db, e.g. lambda ip: asn_lookup(ipaddress.ip_network(ip+"/32"), db).

    Whitelist precedence:
        1. self_ips (config) — never scored
        2. UA whitelist (Privacy Prefetch Proxy, imgix, etc.)
        3. claimed-bot UA — held aside (PTR verification optional, not done here)
        4. Everything else — scored; if score >= threshold and not claimed → blockable

    Output is ready to feed into write_blocked_ips().
    """
    threshold = int(cfg.get("per_ip_threshold", 9))
    ttl_days = int(cfg.get("per_ip_ttl_days", 7))
    self_ips = set(cfg.get("self_ips", []) or [])

    now = datetime.now(timezone.utc)
    expires = now + timedelta(days=ttl_days)
    added_str = now.strftime("%Y-%m-%dT%H:%M:%SZ")
    expires_str = expires.strftime("%Y-%m-%dT%H:%M:%SZ")

    stats = scan_log_per_ip(cfg, window_start)
    out = []
    for ip, s in stats.items():
        if ip in self_ips:
            continue
        if is_ua_whitelisted(s["ua_set"]):
            continue
        if is_claimed_bot(s["ua_set"]):
            # Claimed bots are held aside. PTR verification can be added later.
            continue
        asn_desc = asn_lookup_fn(ip) or ""
        score, sigs = score_ip(s, asn_desc, cfg)
        if score >= threshold:
            out.append({
                "ip":      ip,
                "score":   score,
                "reasons": ",".join(sigs),
                "added":   added_str,
                "expires": expires_str,
                "reqs":    s["reqs"],
                "asn":     asn_desc[:50],
            })
    return out


def write_blocked_ips(path, manual, auto):
    """Wrapper around write_blocked for per-IP entries.

    Accepts auto entries from `find_blockable_ips` (keys: ip, reasons, ...) and
    normalises them to the format `write_blocked` expects (`cidr`, `reason`).
    Nginx geo accepts both single IPs and CIDR ranges in the same line format,
    so the writer is fully reused.
    """
    normalized = [
        {
            **e,
            "cidr":   e.get("cidr") or e["ip"],
            "reason": e.get("reason") or e.get("reasons", ""),
        }
        for e in auto
    ]
    write_blocked(path, manual, normalized)


def score_ip(stats, asn_desc, cfg):
    """Score a single IP's behavioral fingerprint. Returns (score, signals_list).

    Path-agnostic — same algorithm applies whether the IP hit /reservation/<UUID>
    once or hammered /api/* a hundred times. Signals naturally activate based on
    the volume of data available (some require min_reqs).

    `cfg` may carry per-signal tuning (per_ip_chrome_min_version, etc.). Empty
    dict accepts all defaults.

    Reference backtest on ~116k log lines / 25k IPs from a Laravel-fronted
    site over 48h:
        - threshold=9 → ~395 IPs flagged (~1.5% of seen IPs)
        - 69% confirmed hosting by ip-api, 26% proxy
        - 0% false-positive rate after UA whitelist
        - catches ~9% of residential scrapers that ip-api alone misses
    """
    n = stats.get("reqs", 0)
    if n == 0:
        return 0, []

    asset_ratio = stats.get("assets", 0) / n
    no_ref_ratio = stats.get("no_ref", 0) / n
    has_ref = stats.get("ext_ref", 0) + stats.get("int_ref", 0)
    ext_ref_ratio = stats.get("ext_ref", 0) / max(has_ref, 1)
    fourxx_ratio = stats.get("status_4xx", 0) / n
    paths = stats.get("paths", set())
    unique_path_ratio = len(paths) / n if n else 0
    ua_set = stats.get("ua_set", set())

    chrome_min = cfg.get("per_ip_chrome_min_version", SUSPICIOUS_CHROME_THRESHOLD)

    pts = 0
    sigs = []

    # S1 — no asset loads: real browsers fetch CSS/JS/images alongside HTML
    if asset_ratio < 0.05 and n >= 3:
        pts += 3
        sigs.append("noassets")

    # S2 — no referer dominant: real users mostly arrive via in-site navigation
    if no_ref_ratio > 0.8 and n >= 2:
        pts += 2
        sigs.append("noref")

    # S3 — external referer dominant: arriving via external links is a scraper
    # pattern (target list from a 3rd-party source)
    if ext_ref_ratio > 0.5 and has_ref >= 3:
        pts += 1
        sigs.append("extref")

    # S4 — 4xx probing: scanners hit non-existent paths
    if fourxx_ratio > 0.3 and n >= 5:
        pts += 1
        sigs.append("4xx")

    # S5 — every request is a different URL: classic crawler / list-scraping pattern
    if unique_path_ratio >= 0.95 and n >= 5:
        pts += 2
        sigs.append("upath")

    # S6 — cloud/hosting ASN: real users come from ISP, not datacenter
    if is_hosting_asn(asn_desc):
        pts += 3
        sigs.append("cloud")

    # S7 — UA quality: detect headless, old Chrome (>6mo), suspicious short UA
    ua_flags = []
    ua_extra = 0
    for ua in ua_set:
        if HEADLESS_UA_RE.search(ua or ""):
            ua_extra = max(ua_extra, 3); ua_flags.append("headless")
        if is_old_chrome(ua, chrome_min):
            ua_extra = max(ua_extra, 2); ua_flags.append("oldchrome")
        if not ua or ua == "-":
            ua_extra = max(ua_extra, 2); ua_flags.append("ua_empty")
        elif len(ua) < 20:
            ua_extra = max(ua_extra, 2); ua_flags.append("ua_short")
    if ua_extra > 0:
        pts += ua_extra
        sigs.append("ua:" + ",".join(sorted(set(ua_flags))))

    return pts, sigs


# ─────────────────────────────────────────────────────────────────
# UA-cluster scoring — aggregate by User-Agent, score the cluster
# (Added in v1.2.)
#
# The subnet pass scores /24s; the per-IP pass scores /32s. Both score IPs in
# isolation, so a distributed scraping botnet defeats both by design — hundreds
# of IPs, ~1 request each, every IP individually innocent.
#
# But such a botnet shares a tiny pool of User-Agent strings across its whole
# IP fleet. That sharing is an AGGREGATE property — invisible to any per-IP
# scorer. The UA-cluster pass groups requests by UA and scores the cluster.
#
# A genuinely popular real-browser UA is also shared by many IPs — but those
# IPs are residential and behave normally, so the cluster scores low. The
# discriminators are hosting-ASN ratio and behavior, NOT raw IP count.
#
# Disabled by default (ua_cluster_enabled=false). Output goes to a SEPARATE
# file (blocked_ua_cluster_conf) at /32 granularity.

def hosting_ratio_for_ips(ips, asn_lookup_fn):
    """Fraction (0.0-1.0) of IPs whose ASN description matches a hosting/cloud
    keyword. `asn_lookup_fn` maps ip_str -> asn_description_str."""
    ips = list(ips)
    if not ips:
        return 0.0
    hosting = sum(1 for ip in ips if is_hosting_asn(asn_lookup_fn(ip)))
    return hosting / len(ips)


def score_ua_cluster(stats, hosting_ratio, cfg):
    """Score a UA-cluster — a User-Agent shared across many distinct IPs.

    `stats` carries cluster-wide aggregates: ua, reqs, assets, no_ref,
    status_4xx. IP count is NOT scored here — it does not discriminate a
    botnet from a popular browser; it only gates which UAs reach this function
    (see find_blockable_ua_clusters).

    `hosting_ratio` is the fraction of cluster member IPs on a hosting/cloud
    ASN, computed by the caller via hosting_ratio_for_ips().

    Returns (score, signals_list). Max 13; default block threshold 7.
    """
    n = stats.get("reqs", 0)
    if n == 0:
        return 0, []

    chrome_min = cfg.get("per_ip_chrome_min_version", SUSPICIOUS_CHROME_THRESHOLD)
    pts = 0
    sigs = []

    # S1 — hosting-ASN ratio: a popular real UA spreads across residential
    # ISPs; a botnet fleet sits on datacenter / proxy infrastructure.
    if hosting_ratio >= 0.5:
        pts += 2
        sigs.append(f"host{int(hosting_ratio * 100)}%")
    if hosting_ratio >= 0.8:
        pts += 2
        sigs.append("host+")

    # S2 — cluster loads no assets: real browsers fetch CSS/JS/images.
    asset_ratio = stats.get("assets", 0) / n
    if asset_ratio < 0.05 and n >= 20:
        pts += 3
        sigs.append("noassets")

    # S3 — cluster sends no referers: real users navigate via in-site links.
    no_ref_ratio = stats.get("no_ref", 0) / n
    if no_ref_ratio > 0.8 and n >= 10:
        pts += 2
        sigs.append("noref")

    # S4 — cluster probes for 4xx: scanner pattern.
    fourxx_ratio = stats.get("status_4xx", 0) / n
    if fourxx_ratio > 0.3 and n >= 20:
        pts += 1
        sigs.append("4xx")

    # S5 — UA quality: headless / old Chrome / thin or empty UA.
    ua = stats.get("ua", "")
    ua_extra = 0
    ua_flags = []
    if HEADLESS_UA_RE.search(ua or ""):
        ua_extra = max(ua_extra, 3); ua_flags.append("headless")
    if is_old_chrome(ua, chrome_min):
        ua_extra = max(ua_extra, 2); ua_flags.append("oldchrome")
    if not ua or ua == "-":
        ua_extra = max(ua_extra, 2); ua_flags.append("ua_empty")
    elif len(ua) < 20:
        ua_extra = max(ua_extra, 2); ua_flags.append("ua_short")
    if ua_extra > 0:
        pts += ua_extra
        sigs.append("ua:" + ",".join(sorted(set(ua_flags))))

    return pts, sigs


def scan_log_ua_cluster(cfg, window_start=None):
    """Parse the access log into per-UA cluster stats.

    Returns dict[ua_str] -> {ips:set, reqs, assets, no_ref, status_4xx}.
    """
    stats = defaultdict(lambda: {
        "ips": set(), "reqs": 0, "assets": 0, "no_ref": 0, "status_4xx": 0,
    })
    p = Path(cfg["access_log"])
    if not p.exists():
        logging.error("access log not found: %s", p)
        return stats
    with p.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            m = LOG_RE.match(line)
            if not m:
                continue
            ip, ts_str, _method, path, _proto, status, referer, ua = m.groups()
            try:
                ts = datetime.strptime(ts_str, "%d/%b/%Y:%H:%M:%S %z")
            except ValueError:
                continue
            if window_start is not None and ts < window_start:
                continue
            s = stats[(ua or "")[:UA_MAX_LENGTH]]
            s["ips"].add(ip)
            s["reqs"] += 1
            if ASSET_RE.search(path):
                s["assets"] += 1
            if referer == "-" or not referer:
                s["no_ref"] += 1
            if status.startswith("4"):
                s["status_4xx"] += 1
    return stats


def find_blockable_ua_clusters(cfg, asn_lookup_fn, window_start=None):
    """Run the UA-cluster pass. Returns a list of cluster dicts:
        {ua, score, reasons, ip_count, hosting_ratio, reqs, ips, added, expires}

    A cluster is a User-Agent shared across >= ua_cluster_min_ips distinct IPs.
    Whitelisted and claimed-bot UAs are skipped (same whitelists as the per-IP
    pass). A cluster below the ua_cluster_min_hosting hosting-ratio floor is
    gated out regardless of behavioral score (see the gate note below). The
    member IPs of a remaining cluster scoring >= ua_cluster_threshold are
    returned for blocking.
    """
    min_ips     = int(cfg.get("ua_cluster_min_ips", 30))
    threshold   = int(cfg.get("ua_cluster_threshold", 7))
    ttl_days    = int(cfg.get("ua_cluster_ttl_days", 7))
    min_hosting = float(cfg.get("ua_cluster_min_hosting", 0.5))
    self_ips    = set(cfg.get("self_ips", []) or [])

    now = datetime.now(timezone.utc)
    added_str   = now.strftime("%Y-%m-%dT%H:%M:%SZ")
    expires_str = (now + timedelta(days=ttl_days)).strftime("%Y-%m-%dT%H:%M:%SZ")

    clusters = scan_log_ua_cluster(cfg, window_start)
    out = []
    for ua, s in clusters.items():
        ips = s["ips"] - self_ips
        if len(ips) < min_ips:
            continue
        if is_ua_whitelisted({ua}):
            continue
        if is_claimed_bot({ua}):
            # Claimed bots are held aside, same as the per-IP pass.
            continue
        hosting_ratio = hosting_ratio_for_ips(ips, asn_lookup_fn)
        # Hosting-ratio gate. Behind a CDN, static assets are edge-cached, so
        # the `noassets` behavioral signal fires on real-user clusters too — a
        # residential cluster can reach the score threshold on CDN artifacts.
        # Hosting-ASN ratio is the discriminator that survives a CDN: a cluster
        # below the floor is never blocked. Set ua_cluster_min_hosting=0 to
        # disable (only for origins NOT behind a CDN).
        if hosting_ratio < min_hosting:
            continue
        sc, sigs = score_ua_cluster(
            {"ua": ua, "reqs": s["reqs"], "assets": s["assets"],
             "no_ref": s["no_ref"], "status_4xx": s["status_4xx"]},
            hosting_ratio, cfg,
        )
        if sc >= threshold:
            out.append({
                "ua":            ua,
                "score":         sc,
                "reasons":       ",".join(sigs),
                "ip_count":      len(ips),
                "hosting_ratio": hosting_ratio,
                "reqs":          s["reqs"],
                "ips":           sorted(ips),
                "added":         added_str,
                "expires":       expires_str,
            })
    return out


# ─────────────────────────────────────────────────────────────────
# IP reputation cache + ip-api.com batch

def load_rep_cache(path):
    p = Path(path)
    if not p.exists():
        return {}
    try:
        return json.loads(p.read_text())
    except (json.JSONDecodeError, OSError) as e:
        logging.warning("reputation cache unreadable, starting fresh: %s", e)
        return {}


def save_rep_cache(path, cache):
    p = Path(path)
    p.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    tmp = p.with_suffix(".tmp")
    tmp.write_text(json.dumps(cache, indent=2, sort_keys=True))
    tmp.rename(p)


def query_ipapi_batch(ips, cfg):
    """POST batch query to ip-api.com. Returns {ip: {hosting, proxy, ...}} or {}."""
    if not ips:
        return {}
    payload = json.dumps([{"query": ip} for ip in ips]).encode()
    req = urllib.request.Request(
        cfg["ipapi_batch_url"],
        data=payload,
        headers={"Content-Type": "application/json"},
    )
    try:
        with urllib.request.urlopen(req, timeout=cfg["ipapi_timeout"]) as resp:
            data = json.loads(resp.read())
    except (urllib.error.URLError, ValueError, OSError) as e:
        logging.warning("ip-api batch failed for %d IPs: %s", len(ips), e)
        return {}
    results = {}
    for item in data:
        ip = item.get("query", "")
        if not ip:
            continue
        results[ip] = {
            "hosting": bool(item.get("hosting")),
            "proxy":   bool(item.get("proxy")),
            "mobile":  bool(item.get("mobile")),
            "isp":     item.get("isp", ""),
            "country": item.get("country", ""),
            "as":      item.get("as", ""),
        }
    return results


def enrich_with_reputation(candidates_with_stats, cache, cfg):
    """
    For each (subnet, stats) ensures cache has fresh ip-api data.
    Sample IP is taken from observed log entries (NOT network address)
    because .0 addresses can have different classification than active hosts.
    """
    if not cfg["use_ipapi"]:
        return {}
    now = int(time.time())
    ttl = cfg["rep_cache_ttl_days"] * 86400
    result = {}
    need_query = []  # list of (cidr_str, sample_ip)

    for net, s in candidates_with_stats:
        cidr = str(net)
        entry = cache.get(cidr)
        if entry and "ipapi" in entry and (now - entry.get("queried_at", 0)) < ttl:
            result[cidr] = entry["ipapi"]
            continue
        ips_in_log = s.get("ips") if s else None
        sample_ip = next(iter(ips_in_log)) if ips_in_log else str(net.network_address)
        need_query.append((cidr, sample_ip))

    batch_size = cfg["ipapi_batch_size"]
    for start in range(0, len(need_query), batch_size):
        chunk = need_query[start:start + batch_size]
        ips = [s for _, s in chunk]
        batch_results = query_ipapi_batch(ips, cfg)
        for cidr, sample_ip in chunk:
            ipapi_data = batch_results.get(sample_ip)
            if ipapi_data is None:
                continue
            cache[cidr] = {
                "queried_at": now,
                "sample_ip":  sample_ip,
                "ipapi":      ipapi_data,
            }
            result[cidr] = ipapi_data
    return result


# ─────────────────────────────────────────────────────────────────
# Log scanning

def subnet_for(ip_str, ipv6_prefix):
    ip = ipaddress.ip_address(ip_str)
    prefix = 24 if isinstance(ip, ipaddress.IPv4Address) else ipv6_prefix
    return ipaddress.ip_network(f"{ip}/{prefix}", strict=False)


def is_target_path(path, target_paths, excluded_paths):
    """True if path matches target_paths AND not excluded_paths."""
    for ex in excluded_paths:
        if path.startswith(ex):
            return False
    for t in target_paths:
        if path.startswith(t) or t in path:
            return True
    return False


def normalize_path(path):
    """Drop query string for path concentration grouping."""
    return path.split("?", 1)[0]


def scan_log(window_start, cfg):
    stats = defaultdict(lambda: {
        "requests":     0,
        "uas":          Counter(),
        "ips":          set(),
        "target":       0,
        "with_referer": 0,
        "paths":        Counter(),
    })
    p = Path(cfg["access_log"])
    if not p.exists():
        logging.error("access log not found: %s", p)
        return stats
    with p.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            m = LOG_RE.match(line)
            if not m:
                continue
            ip, ts_str, _method, path, _proto, _status, referer, ua = m.groups()
            try:
                ts = datetime.strptime(ts_str, "%d/%b/%Y:%H:%M:%S %z")
            except ValueError:
                continue
            if ts < window_start:
                continue
            try:
                net = subnet_for(ip, cfg["ipv6_prefix"])
            except ValueError:
                continue
            s = stats[net]
            s["requests"] += 1
            s["uas"][ua] += 1
            s["ips"].add(ip)
            if is_target_path(path, cfg["target_paths"], cfg["excluded_paths"]):
                s["target"] += 1
            if referer and referer != "-":
                s["with_referer"] += 1
            s["paths"][normalize_path(path)] += 1
    return stats


# ─────────────────────────────────────────────────────────────────
# Scoring (max 11)

def score(s, asn_desc, ipapi):
    """
    Composite bot signal score. Signals:
    - UA diversity ≤ 2:           +2  (homogeneous bot farm signature)
    - Target paths ≥ 50% / ≥ 80%: +1 / +1 additional
    - Top-3 paths ≥ 50% / ≥ 80%:  +1 / +1 additional  (low URL diversity)
    - Referer rate < 30% / < 10%: +1 / +1 additional  (real browsers send referer)
    - ip-api hosting OR proxy:    +3  (datacenter/proxy = strong bot signal)
        - falls back to ASN keyword match if ip-api unavailable
    - ip-api mobile=true:         -1  (mobile carrier = likely real users)
    """
    pts = 0
    parts = []
    n = s["requests"]

    if len(s["uas"]) <= 2:
        pts += 2; parts.append(f"ua{len(s['uas'])}")

    target_ratio = s["target"] / n
    if target_ratio >= 0.5:
        pts += 1; parts.append(f"tgt{int(target_ratio*100)}%")
    if target_ratio >= 0.8:
        pts += 1; parts.append("tgt+")

    top3 = sum(c for _, c in s["paths"].most_common(3))
    top3_ratio = top3 / n
    if top3_ratio >= 0.5:
        pts += 1; parts.append(f"top3_{int(top3_ratio*100)}%")
    if top3_ratio >= 0.8:
        pts += 1; parts.append("top3+")

    referer_ratio = s["with_referer"] / n
    if referer_ratio < 0.30:
        pts += 1; parts.append(f"ref{int(referer_ratio*100)}%")
    if referer_ratio < 0.10:
        pts += 1; parts.append("ref+")

    if ipapi is not None:
        tags = []
        if ipapi.get("hosting"): tags.append("host")
        if ipapi.get("proxy"):   tags.append("proxy")
        if tags:
            pts += 3
            parts.append("ipapi:" + "+".join(tags))
        elif ipapi.get("mobile"):
            pts -= 1
            parts.append("mobile-1")
    elif is_hosting_asn(asn_desc):
        # Fallback when ip-api unavailable
        pts += 3
        parts.append("asn:" + (asn_desc or "")[:25].replace(" ", "_"))

    return pts, " ".join(parts)


def evaluate(stats, whitelist, asn_db, rep_cache, cfg):
    candidates_pre = []
    for net, s in stats.items():
        if s["requests"] < cfg["min_requests"]:
            continue
        if is_whitelisted(net, whitelist):
            continue
        candidates_pre.append((net, s))

    reputations = enrich_with_reputation(candidates_pre, rep_cache, cfg)

    out = []
    for net, s in candidates_pre:
        asn_desc = asn_lookup(net, asn_db)
        ipapi = reputations.get(str(net))
        pts, reasons = score(s, asn_desc, ipapi)
        if pts >= cfg["score_threshold"]:
            out.append((net, pts, reasons, s["requests"]))
    return out


def all_scored(stats, whitelist, asn_db, rep_cache, cfg, limit=30):
    candidates_pre = [(net, s) for net, s in stats.items()
                      if s["requests"] >= cfg["min_requests"]]
    reputations = enrich_with_reputation(candidates_pre, rep_cache, cfg)
    rows = []
    for net, s in candidates_pre:
        wl = is_whitelisted(net, whitelist)
        asn_desc = asn_lookup(net, asn_db)
        ipapi = reputations.get(str(net))
        pts, reasons = score(s, asn_desc, ipapi)
        rows.append((pts, net, s["requests"], reasons, wl, s, asn_desc, ipapi))
    rows.sort(key=lambda x: (-x[0], -x[2]))
    return rows[:limit]


# ─────────────────────────────────────────────────────────────────
# Blocked file management

def read_blocked(path):
    """
    Returns (manual_lines, auto_entries).

    The auto section is delimited by AUTO_BEGIN_MARKER / AUTO_END_MARKER.
    Everything between markers is "auto" and gets rewritten on every run.
    Everything outside is "manual" and is preserved verbatim.

    For legacy files without markers, falls back to detecting auto entries
    by pattern (AUTO_RE) wherever they appear.
    """
    manual, auto = [], []
    p = Path(path)
    if not p.exists():
        return manual, auto

    lines = p.read_text().splitlines()
    has_markers = any(line.strip() == AUTO_BEGIN_MARKER for line in lines)

    in_auto = False
    for line in lines:
        stripped = line.strip()
        if stripped == AUTO_BEGIN_MARKER:
            in_auto = True
            continue
        if stripped == AUTO_END_MARKER:
            in_auto = False
            continue
        if in_auto:
            m = AUTO_RE.match(line)
            if m:
                cidr, added, expires, reason = m.groups()
                auto.append({"cidr": cidr, "added": added, "expires": expires, "reason": reason})
            # Non-entry lines inside auto section (managed headers) — drop them
            continue
        # Outside auto section
        if has_markers:
            manual.append(line)
        else:
            # Legacy file: detect auto entries by pattern, drop legacy headers
            m = AUTO_RE.match(line)
            if m:
                cidr, added, expires, reason = m.groups()
                auto.append({"cidr": cidr, "added": added, "expires": expires, "reason": reason})
            elif stripped in _LEGACY_AUTO_HEADERS:
                continue  # legacy duplicate header → strip
            else:
                manual.append(line)
    return manual, auto


def write_blocked(path, manual, auto):
    """
    Layout:
        <manual lines verbatim, trailing blank lines stripped>
        <blank line>
        AUTO_BEGIN_MARKER
        <2 explanatory comment lines>
        <auto entries, sorted by added timestamp>
        AUTO_END_MARKER
    Auto section is omitted entirely when there are no auto entries.
    """
    cleaned_manual = list(manual)
    while cleaned_manual and not cleaned_manual[-1].strip():
        cleaned_manual.pop()

    out = list(cleaned_manual)
    if auto:
        if out:
            out.append("")
        out.append(AUTO_BEGIN_MARKER)
        out.append("# Managed by autoblock script. Lines below auto-expire per TTL.")
        out.append("# To unblock early: delete the line + sudo nginx -s reload")
        for e in sorted(auto, key=lambda x: x["added"]):
            out.append(
                f"{e['cidr']} 1; # auto added={e['added']} "
                f"expires={e['expires']} reason={e['reason']}"
            )
        out.append(AUTO_END_MARKER)
    Path(path).write_text("\n".join(out) + "\n")


def nginx_reload():
    test = subprocess.run(["nginx", "-t"], capture_output=True, text=True)
    if test.returncode != 0:
        logging.error("nginx -t failed: %s", test.stderr.strip())
        return False
    rel = subprocess.run(["nginx", "-s", "reload"], capture_output=True, text=True)
    if rel.returncode != 0:
        logging.error("nginx reload failed: %s", rel.stderr.strip())
        return False
    return True


def manual_cidrs(manual_lines):
    out = set()
    for line in manual_lines:
        m = re.match(r"^\s*(\S+) 1;", line)
        if m and not line.lstrip().startswith("#"):
            out.add(m.group(1))
    return out


# ─────────────────────────────────────────────────────────────────
# Commands

def cmd_run(cfg, dry_run=False):
    now = datetime.now(timezone.utc)
    window_start = now - timedelta(minutes=cfg["window_minutes"])
    whitelist = load_whitelist(cfg["whitelist"])
    asn_db = load_asn_db(cfg["asn_db"])
    rep_cache = load_rep_cache(cfg["rep_cache"])
    stats = scan_log(window_start, cfg)
    candidates = evaluate(stats, whitelist, asn_db, rep_cache, cfg)

    save_rep_cache(cfg["rep_cache"], rep_cache)

    if not candidates:
        logging.info("scan: %d subnets in window, 0 candidates (threshold=%d)",
                     len(stats), cfg["score_threshold"])
        return

    manual, auto = read_blocked(cfg["blocked_conf"])
    manual_set = manual_cidrs(manual)
    auto_by_cidr = {e["cidr"]: e for e in auto}

    new_expires = (now + timedelta(days=cfg["ttl_days"])).strftime("%Y-%m-%dT%H:%M:%SZ")
    now_str = now.strftime("%Y-%m-%dT%H:%M:%SZ")

    added, extended = [], []
    for net, pts, reasons, n in candidates:
        cidr = str(net)
        full_reason = f"score{pts}/11 {n}req {reasons}"
        if cidr in manual_set:
            continue
        if cidr in auto_by_cidr:
            auto_by_cidr[cidr]["expires"] = new_expires
            auto_by_cidr[cidr]["reason"] = full_reason
            extended.append(cidr)
            continue
        auto.append({"cidr": cidr, "added": now_str, "expires": new_expires, "reason": full_reason})
        added.append((cidr, full_reason))

    for cidr, r in added:
        logging.info("BLOCK %s — %s", cidr, r)
    for cidr in extended:
        logging.info("EXTEND %s — TTL refreshed", cidr)

    if dry_run:
        logging.info("--dry-run: %d new, %d extended — NOT applied",
                     len(added), len(extended))
        return

    if not added and not extended:
        return

    write_blocked(cfg["blocked_conf"], manual, auto)
    if nginx_reload():
        logging.info("reloaded: %d new, %d extended", len(added), len(extended))
    else:
        logging.error("RELOAD FAILED, blocks written but not active")


def cmd_show_scores(cfg):
    now = datetime.now(timezone.utc)
    window_start = now - timedelta(minutes=cfg["window_minutes"])
    whitelist = load_whitelist(cfg["whitelist"])
    asn_db = load_asn_db(cfg["asn_db"])
    rep_cache = load_rep_cache(cfg["rep_cache"])
    stats = scan_log(window_start, cfg)
    rows = all_scored(stats, whitelist, asn_db, rep_cache, cfg, limit=30)
    save_rep_cache(cfg["rep_cache"], rep_cache)

    print(f"\nWindow: last {cfg['window_minutes']} min, total subnets: {len(stats)}, "
          f"ASN DB: {'loaded' if asn_db else 'MISSING'}, cached reputations: {len(rep_cache)}")
    print(f"Threshold: ≥{cfg['score_threshold']}/11")
    print("Signals: UA(+2) Target(+1/+1) Top3(+1/+1) Ref(+1/+1) ip-api[host|proxy](+3) mobile(-1)\n")
    print(f"{'SCORE':>5} {'SUBNET':<22} {'REQS':>5} {'MARK':<5} {'UA':>2} {'TGT%':>4} {'TOP3%':>5} {'REF%':>4}  ipapi  ASN")
    print("-" * 140)
    for pts, net, n, reasons, wl, s, asn_desc, ipapi in rows:
        marker = "WL" if wl else ("*BLK*" if pts >= cfg["score_threshold"] else "")
        ua_n = len(s["uas"])
        tgt_pct = int(s["target"] * 100 / n)
        top3 = sum(c for _, c in s["paths"].most_common(3))
        top3_pct = int(top3 * 100 / n)
        ref_pct = int(s["with_referer"] * 100 / n)
        if ipapi is None:
            ipapi_tag = "?"
        else:
            tags = []
            if ipapi.get("hosting"): tags.append("H")
            if ipapi.get("proxy"):   tags.append("P")
            if ipapi.get("mobile"):  tags.append("M")
            ipapi_tag = "".join(tags) or "-"
        asn_short = (asn_desc or "?")[:50]
        print(f"{pts:>5} {str(net):<22} {n:>5} {marker:<5} {ua_n:>2} {tgt_pct:>3}% {top3_pct:>4}% {ref_pct:>3}%  {ipapi_tag:<5}  {asn_short}")
    if not rows:
        print(f"(no subnets above min_requests={cfg['min_requests']})")


def cmd_cleanup(cfg):
    now = datetime.now(timezone.utc)
    any_changed = False

    # Cleanup every pass's block file (subnet + per-IP + UA-cluster)
    for path_key, label in [("blocked_conf", "subnet"),
                            ("blocked_ips_conf", "per-IP"),
                            ("blocked_ua_cluster_conf", "ua-cluster")]:
        path = cfg.get(path_key)
        if not path or not Path(path).exists():
            continue
        manual, auto = read_blocked(path)
        kept, removed = [], []
        for e in auto:
            try:
                exp = datetime.strptime(e["expires"], "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
            except ValueError:
                kept.append(e); continue
            if exp < now:
                removed.append(e["cidr"])
            else:
                kept.append(e)
        if removed:
            for cidr in removed:
                logging.info("UNBLOCK-%s %s — expired", label, cidr)
            write_blocked(path, manual, kept)
            any_changed = True
        else:
            logging.info("cleanup %s: nothing expired", label)

    if any_changed:
        if nginx_reload():
            logging.info("reloaded after cleanup")

    # Prune stale reputation cache entries
    rep_cache = load_rep_cache(cfg["rep_cache"])
    now_ts = int(time.time())
    ttl = cfg["rep_cache_ttl_days"] * 86400
    stale = [k for k, v in rep_cache.items() if (now_ts - v.get("queried_at", 0)) > ttl]
    for k in stale:
        del rep_cache[k]
    if stale:
        save_rep_cache(cfg["rep_cache"], rep_cache)
        logging.info("rep cache: pruned %d stale entries", len(stale))


def cmd_per_ip(cfg, dry_run=False, show_only=False):
    """Per-IP behavioral scoring pass (added v1.1).

    Independent from the subnet pass. Writes to `blocked_ips_conf` (separate
    file). Can be run standalone via --per-ip, or auto-runs after subnet pass
    when per_ip_enabled=true.
    """
    asn_db = load_asn_db(cfg["asn_db"])
    if asn_db is None:
        logging.warning("per-IP pass: ASN DB missing, cloud signal disabled")

    def asn_lookup_for(ip_str):
        if asn_db is None:
            return ""
        try:
            net = ipaddress.ip_network(ip_str + "/32", strict=False) if "." in ip_str else \
                  ipaddress.ip_network(ip_str + "/128", strict=False)
        except ValueError:
            return ""
        return asn_lookup(net, asn_db) or ""

    # No window_start here — backtest showed scoring works well over full
    # rotation period. Use access_log only (don't read rotated .gz here).
    blockable = find_blockable_ips(cfg, asn_lookup_fn=asn_lookup_for, window_start=None)

    if show_only:
        print(f"\nPer-IP pass: threshold={cfg['per_ip_threshold']}, "
              f"candidates={len(blockable)}")
        print(f"{'SCORE':>5} {'REQS':>5} {'IP':<25} {'ASN':<35} reasons")
        print("-" * 120)
        for b in sorted(blockable, key=lambda x: (-x["score"], -x["reqs"]))[:50]:
            print(f"{b['score']:>5} {b['reqs']:>5} {b['ip']:<25} {b['asn']:<35} {b['reasons']}")
        return

    if not blockable:
        logging.info("per-IP: no candidates above threshold=%d", cfg["per_ip_threshold"])
        return

    # Load existing per-IP block list and merge
    manual, auto = read_blocked(cfg["blocked_ips_conf"])
    manual_set = manual_cidrs(manual)
    auto_by_cidr = {e["cidr"]: e for e in auto}

    added, extended = [], []
    for b in blockable:
        ip = b["ip"]
        if ip in manual_set:
            continue
        full_reason = f"score{b['score']} {b['reqs']}req {b['reasons']}"
        if ip in auto_by_cidr:
            auto_by_cidr[ip]["expires"] = b["expires"]
            auto_by_cidr[ip]["reason"] = full_reason
            extended.append(ip)
        else:
            auto.append({
                "cidr":    ip,
                "added":   b["added"],
                "expires": b["expires"],
                "reason":  full_reason,
            })
            added.append((ip, full_reason))

    for ip, r in added:
        logging.info("BLOCK-IP %s — %s", ip, r)
    for ip in extended:
        logging.info("EXTEND-IP %s — TTL refreshed", ip)

    if dry_run:
        logging.info("--dry-run: per-IP %d new, %d extended — NOT applied",
                     len(added), len(extended))
        return

    if not added and not extended:
        return

    write_blocked(cfg["blocked_ips_conf"], manual, auto)
    if nginx_reload():
        logging.info("reloaded (per-IP): %d new, %d extended", len(added), len(extended))
    else:
        logging.error("RELOAD FAILED (per-IP), blocks written but not active")


def cmd_ua_cluster(cfg, dry_run=False, show_only=False):
    """UA-cluster pass (added v1.2).

    Groups requests by User-Agent, scores each cluster of >= ua_cluster_min_ips
    distinct IPs, and blocks the member IPs of confirmed botnet clusters.
    Independent from the other passes; writes to `blocked_ua_cluster_conf`.
    Can be run standalone via --ua-cluster, or auto-runs after the subnet and
    per-IP passes when ua_cluster_enabled=true.
    """
    asn_db = load_asn_db(cfg["asn_db"])
    if asn_db is None:
        logging.warning("UA-cluster pass: ASN DB missing, hosting signal disabled")

    def asn_lookup_for(ip_str):
        if asn_db is None:
            return ""
        try:
            net = ipaddress.ip_network(
                ip_str + ("/32" if "." in ip_str else "/128"), strict=False)
        except ValueError:
            return ""
        return asn_lookup(net, asn_db) or ""

    # No window_start — like the per-IP pass, scoring works over the full
    # rotation period of the live access log.
    clusters = find_blockable_ua_clusters(cfg, asn_lookup_fn=asn_lookup_for,
                                          window_start=None)

    if show_only:
        print(f"\nUA-cluster pass: threshold={cfg['ua_cluster_threshold']}, "
              f"min_ips={cfg['ua_cluster_min_ips']}, clusters flagged={len(clusters)}")
        print(f"{'SCORE':>5} {'IPS':>6} {'HOST%':>6} {'REQS':>8}  {'REASONS':<28} UA")
        print("-" * 120)
        for c in sorted(clusters, key=lambda x: (-x["score"], -x["ip_count"])):
            print(f"{c['score']:>5} {c['ip_count']:>6} "
                  f"{int(c['hosting_ratio'] * 100):>5}% {c['reqs']:>8}  "
                  f"{c['reasons']:<28} {c['ua'][:64]}")
        if not clusters:
            print(f"(no UA shared by >= {cfg['ua_cluster_min_ips']} IPs scored "
                  f">= {cfg['ua_cluster_threshold']})")
        return

    if not clusters:
        logging.info("UA-cluster: no clusters above threshold=%d",
                     cfg["ua_cluster_threshold"])
        return

    manual, auto = read_blocked(cfg["blocked_ua_cluster_conf"])
    manual_set = manual_cidrs(manual)
    auto_by_cidr = {e["cidr"]: e for e in auto}

    added, extended = [], []
    for c in clusters:
        ua_tag = re.sub(r"\s+", "_", c["ua"])[:40]
        full_reason = (f"ua-cluster score{c['score']} {c['ip_count']}ips "
                       f"host{int(c['hosting_ratio'] * 100)}% {c['reasons']} "
                       f"ua={ua_tag}")
        logging.info("UA-CLUSTER score%d %d IPs host%d%% [%s] — UA: %s",
                     c["score"], c["ip_count"],
                     int(c["hosting_ratio"] * 100), c["reasons"], c["ua"])
        for ip in c["ips"]:
            if ip in manual_set:
                continue
            if ip in auto_by_cidr:
                auto_by_cidr[ip]["expires"] = c["expires"]
                auto_by_cidr[ip]["reason"] = full_reason
                extended.append(ip)
            else:
                auto.append({"cidr": ip, "added": c["added"],
                             "expires": c["expires"], "reason": full_reason})
                added.append(ip)

    logging.info("UA-cluster: %d cluster(s) → %d new IPs, %d extended",
                 len(clusters), len(added), len(extended))

    if dry_run:
        logging.info("--dry-run: UA-cluster %d new, %d extended — NOT applied",
                     len(added), len(extended))
        return
    if not added and not extended:
        return

    write_blocked(cfg["blocked_ua_cluster_conf"], manual, auto)
    if nginx_reload():
        logging.info("reloaded (UA-cluster): %d new, %d extended",
                     len(added), len(extended))
    else:
        logging.error("RELOAD FAILED (UA-cluster), blocks written but not active")


def setup_logging(log_file):
    fmt = "%(asctime)s %(levelname)s %(message)s"
    Path(log_file).parent.mkdir(parents=True, exist_ok=True)
    logging.basicConfig(filename=log_file, level=logging.INFO, format=fmt)
    h = logging.StreamHandler(sys.stderr)
    h.setFormatter(logging.Formatter(fmt))
    logging.getLogger().addHandler(h)


def main():
    p = argparse.ArgumentParser(description="nginx-autoblock — behavioral autoblocker for Nginx")
    p.add_argument("--config", default=DEFAULT_CONFIG_PATH, help=f"Config file (default: {DEFAULT_CONFIG_PATH})")
    p.add_argument("--dry-run", action="store_true", help="Show candidates without writing")
    p.add_argument("--show-scores", action="store_true", help="Show top-30 subnets with scores (subnet pass)")
    p.add_argument("--show-per-ip", action="store_true",
                   help="Show top-50 per-IP candidates (path-agnostic pass; diagnostic)")
    p.add_argument("--per-ip", action="store_true",
                   help="Run ONLY the per-IP pass (skip subnet pass)")
    p.add_argument("--show-ua-cluster", action="store_true",
                   help="Show flagged UA-clusters with scores (diagnostic)")
    p.add_argument("--ua-cluster", action="store_true",
                   help="Run ONLY the UA-cluster pass (skip subnet pass)")
    p.add_argument("--cleanup", action="store_true",
                   help="Remove expired auto-bans (subnet, per-IP and UA-cluster)")
    args = p.parse_args()

    cfg = load_config(args.config)
    setup_logging(cfg["log_file"])

    if args.cleanup:
        cmd_cleanup(cfg)
    elif args.show_scores:
        cmd_show_scores(cfg)
    elif args.show_per_ip:
        cmd_per_ip(cfg, dry_run=True, show_only=True)
    elif args.per_ip:
        cmd_per_ip(cfg, dry_run=args.dry_run)
    elif args.show_ua_cluster:
        cmd_ua_cluster(cfg, dry_run=True, show_only=True)
    elif args.ua_cluster:
        cmd_ua_cluster(cfg, dry_run=args.dry_run)
    else:
        cmd_run(cfg, dry_run=args.dry_run)
        if cfg.get("per_ip_enabled"):
            cmd_per_ip(cfg, dry_run=args.dry_run)
        if cfg.get("ua_cluster_enabled"):
            cmd_ua_cluster(cfg, dry_run=args.dry_run)


if __name__ == "__main__":
    main()
