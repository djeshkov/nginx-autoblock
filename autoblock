]

LOG_RE = re.compile(
    r'^(\S+) - - \[([^\]]+)\] "(\S+) (\S+) (\S+)" (\d+) \S+ "([^"]*)" "([^"]*)"'
)
AUTO_RE = re.compile(
    r"^(\S+) 1; # auto added=(\S+) expires=(\S+) reason=(.+)$"
)

# Sentinel markers wrapping the auto-managed section of blocked-subnets.conf.
# Everything BETWEEN these markers is owned by this script and gets rewritten
# on every run. Everything OUTSIDE is treated as manual and preserved.
